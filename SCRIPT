$targets = @(
    @{Name="dps"; Type="Service"},
    @{Name="diagtrack"; Type="Service"},
    @{Name="lsass"; Type="Process"},
    @{Name="dnscache"; Type="Service"},
    @{Name="explorer"; Type="Process"},
