Write-Host "-----------------" -ForegroundColor Cyan

$results = foreach ($t in $targets) {
    if ($t.Type -eq "Process") {
        $proc = Get-Process -Name $t.Name -ErrorAction SilentlyContinue
        if ($proc) {
            [PSCustomObject]@{ Name = $proc.ProcessName; StartTime = $proc.StartTime; Running = $true }
        } else {
            [PSCustomObject]@{ Name = $t.Name; StartTime = $null; Running = $false }
        }
    } else {
        $svc = Get-CimInstance Win32_Service -Filter "Name='$($t.Name)'" -ErrorAction SilentlyContinue
        if ($svc -and $svc.State -eq "Running") {
            try {
                $proc = Get-Process -Id $svc.ProcessId -ErrorAction Stop
                [PSCustomObject]@{ Name = $svc.Name; StartTime = $proc.StartTime; Running = $true }
            } catch {
                [PSCustomObject]@{ Name = $svc.Name; StartTime = $null; Running = $true }
            }
        } else {
            [PSCustomObject]@{ Name = $t.Name; StartTime = $null; Running = $false }
        }
    }
}

$minTime = ($results | Where-Object { $_.StartTime } | Measure-Object StartTime -Minimum).Minimum
foreach ($r in $results) {
    if (-not $r.Running) {
        Write-Host ($r.Name.PadRight(12) + " Stopped") -ForegroundColor Yellow
    } elseif ($r.StartTime) {
        $timeStr = $r.StartTime.ToString("MM/dd/yyyy HH:mm:ss")
        if (($r.StartTime - $minTime).TotalMinutes -gt 20) {
            Write-Host ($r.Name.PadRight(12) + " " + $timeStr) -ForegroundColor Red
        } else {
            Write-Host ($r.Name.PadRight(12) + " " + $timeStr) -ForegroundColor Green
        }
    }
}
 
