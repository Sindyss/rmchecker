using System;
using System.Runtime.InteropServices;
using System.Text;
public class DevicePathResolver {
    [DllImport("kernel32.dll", SetLastError=true)]
    public static extern uint QueryDosDevice(string lpDeviceName, StringBuilder lpTargetPath, int ucchMax);
    public static string GetDeviceTarget(string device) {
        StringBuilder sb = new StringBuilder(1024);
        uint result = QueryDosDevice(device, sb, sb.Capacity);
        if (result != 0) return sb.ToString();
        return null;
    }
}
'@

$SID = (New-Object System.Security.Principal.NTAccount($env:UserName)).Translate([System.Security.Principal.SecurityIdentifier]).Value
$PossibleKeys = @(
    "HKLM:\SYSTEM\CurrentControlSet\Services\bam\UserSettings\$SID",
    "HKLM:\SYSTEM\CurrentControlSet\Services\bam\State\UserSettings\$SID",
    "HKLM:\SYSTEM\CurrentControlSet\Services\bam\State\UserSettingsPersistent\$SID"
)
$BAMKey = $PossibleKeys | Where-Object { Test-Path $_ } | Select-Object -First 1
if (-not $BAMKey) { Write-Host "BAM key not found for $SID" -ForegroundColor Red; exit }

$drives = Get-CimInstance Win32_LogicalDisk | Where-Object { $_.DeviceID -and $_.DriveType -eq 3 }
$VolumeMap = @{}
foreach ($d in $drives) {
    $dev = $d.DeviceID
    $target = [DevicePathResolver]::GetDeviceTarget($dev)
    if ($target) { $VolumeMap[$target] = $dev + "\" }
}

$Entries = @()
$BAMEntries = Get-ItemProperty -Path $BAMKey -ErrorAction SilentlyContinue
foreach ($entry in $BAMEntries.PSObject.Properties) {
    if ($entry.Name -like "PS*") { continue }

    $RawPath = $entry.Name
    $LastRunRaw = $entry.Value
    try { $LastRun = [DateTime]::FromFileTimeUtc([BitConverter]::ToInt64($LastRunRaw,0)).ToLocalTime() } catch { $LastRun = $null }

    $Path = $RawPath
    foreach ($vol in $VolumeMap.Keys) {
        if ($Path.StartsWith($vol, [StringComparison]::OrdinalIgnoreCase)) {
            $rem = $Path.Substring($vol.Length).TrimStart('\')
            $Path = $VolumeMap[$vol] + $rem
            break
        }
    }

    if ($Path -notmatch '^[A-Z]:\\') { continue }

    $FileName = Split-Path $Path -Leaf
    $ext = [System.IO.Path]::GetExtension($FileName).ToLower()
    $SignInfo = "File Was Not Found"

    if (Test-Path $Path) {
        try {
            $Signature = Get-AuthenticodeSignature -FilePath $Path -ErrorAction SilentlyContinue
            if ($Signature -and $Signature.Status -eq "Valid") {
                $SignInfo = "Signed"
            } else {
                $SignInfo = "NotSigned"
            }
        } catch { $SignInfo = "NotSigned" }
    }

    if ($SignInfo -ne "Signed" -or $ext -ne ".exe") {
        $Entries += [PSCustomObject]@{ Time = $LastRun; File = $FileName; Signature = $SignInfo; Path = $Path }
    }
}

$Entries = $Entries | Sort-Object Time -Descending

Write-Host ""
Write-Host ("{0,-16} {1,-25} {2,-18} {3}" -f "------","-------","-------------","-----------") -ForegroundColor Yellow

foreach ($e in $Entries) {
    $timeStr = if ($e.Time) { $e.Time.ToString('dd.MM.yy HH:mm') } else { 'N/A'.PadRight(16) }
    $ext = [System.IO.Path]::GetExtension($e.File)
    if ($ext -ne ".exe") { $Color = "Magenta" }
    elseif ($e.Signature -eq "File Was Not Found") { $Color = "DarkYellow" }
    else { $Color = "Red" }

    $line = ("{0,-16} {1,-25} {2,-18} {3}" -f $timeStr, $e.File, $e.Signature, $e.Path)
    Write-Host $line -ForegroundColor $Color
}
